DEFAULT_HOST = "fakebook.khoury.northeastern.edu"
DEFAULT_PORT = 443

# Secret flags: <h3 class="... secret_flag ...">FLAG: &lt;64 alphanumerics&gt;</h3>
FLAG_RE_H3 = re.compile(
    r"<h3[^>]*\bclass\s*=\s*['\"]([^'\"]*\bsecret_flag\b[^'\"]*)['\"][^>]*>\s*FLAG:\s*([A-Za-z0-9]{64})\s*</h3>",
    re.IGNORECASE | re.DOTALL,
)
FLAG_RE_ANY = re.compile(r"FLAG:\s*([A-Za-z0-9]{64})")


def read_chunked_body_fixed(
    tls_socket: ssl.SSLSocket, bytes_after_headers: bytes
) -> Tuple[bytes, bytes]:
    """Reassemble a chunked body; return (decoded_body, leftover_bytes_after_chunks)."""
    decoded_body = bytearray()
    read_buffer = bytearray(bytes_after_headers)
    while True:
        # Chunk size line ends with CRLF; size is hex, optional extensions after ';'
        while b"\r\n" not in read_buffer:
            chunk = tls_socket.recv(8192)
            if not chunk:
                raise ConnectionError("EOF in chunked size line")
            read_buffer.extend(chunk)
        line_end = read_buffer.index(b"\r\n")
        size_line = bytes(read_buffer[:line_end])
        del read_buffer[: line_end + 2]
        chunk_size_hex = size_line.split(b";", 1)[0].strip()
        chunk_length = int(chunk_size_hex, 16)
        if chunk_length == 0:
            # Optional trailers end with blank line
            while b"\r\n\r\n" not in read_buffer:
                more = tls_socket.recv(8192)
                if not more:
                    break
                read_buffer.extend(more)
            if b"\r\n\r\n" in read_buffer:
                trailer_end = read_buffer.index(b"\r\n\r\n")
                del read_buffer[: trailer_end + 4]
            return bytes(decoded_body), bytes(read_buffer)
        while len(read_buffer) < chunk_length + 2:
            more = tls_socket.recv(8192)
            if not more:
                raise ConnectionError("EOF in chunk data")
            read_buffer.extend(more)
        decoded_body.extend(read_buffer[:chunk_length])
        del read_buffer[:chunk_length]
        if read_buffer[:2] != b"\r\n":
            raise ValueError("invalid chunk terminator")
        del read_buffer[:2]


# Cookies: parse Set-Cookie lines into a single Cookie: header value
class CookieJar:
    def __init__(self) -> None:
        self._cookies: Dict[str, str] = {}

    def set_from_lines(self, set_cookie_header_values: List[str]) -> None:
        for header_value in set_cookie_header_values:
            if not header_value.strip():
                continue
            # Only the name=value pair; ignore Path, HttpOnly, etc.
            name_value = header_value.split(";", 1)[0].strip()
            if "=" in name_value:
                cookie_name, cookie_value = name_value.split("=", 1)
                self._cookies[cookie_name.strip()] = cookie_value.strip()

    def header_value(self) -> str:
        if not self._cookies:
            return ""
        return "; ".join(f"{name}={value}" for name, value in self._cookies.items())


def build_request(
    method: str,
    request_path: str,
    host_header: str,
    extra_headers: Optional[Dict[str, str]] = None,
    body: Optional[bytes] = None,
) -> bytes:
    """Build a minimal HTTP/1.1 request (Connection: close)."""
    all_headers: Dict[str, str] = {
        "Host": host_header,
        "Connection": "close",
        "User-Agent": "CS4700-FakebookCrawler/1.0",
    }
    if extra_headers:
        all_headers.update(extra_headers)
    if body is not None:
        all_headers["Content-Length"] = str(len(body))
    request_lines = [f"{method} {request_path} HTTP/1.1"]
    for header_name, header_value in all_headers.items():
        request_lines.append(f"{header_name}: {header_value}")
    request_lines.append("")
    header_bytes = "\r\n".join(request_lines).encode("ascii") + b"\r\n"
    if body:
        return header_bytes + body
    return header_bytes


def raw_read_status_and_headers(
    tls_socket: ssl.SSLSocket,
) -> Tuple[int, Dict[str, str], bytes, List[str]]:
    """Read status line + headers until blank line; return status, headers, first body bytes, Set-Cookie lines."""
    read_buffer = bytearray()
    while b"\r\n\r\n" not in read_buffer:
        chunk = tls_socket.recv(8192)
        if not chunk:
            raise ConnectionError("unexpected EOF while reading headers")
        read_buffer.extend(chunk)
        if len(read_buffer) > 2 * 1024 * 1024:
            raise ValueError("headers too large")
    header_end = read_buffer.index(b"\r\n\r\n")
    header_blob = bytes(read_buffer[:header_end])
    bytes_after_headers = bytes(read_buffer[header_end + 4 :])
    raw_lines = header_blob.split(b"\r\n")
    status_line = raw_lines[0].decode("latin-1", errors="replace")
    status_parts = status_line.split(None, 2)
    status_code = int(status_parts[1])
    response_headers: Dict[str, str] = {}
    for raw_line in raw_lines[1:]:
        if not raw_line or b":" not in raw_line:
            continue
        name_bytes, value_bytes = raw_line.split(b":", 1)
        header_name = name_bytes.decode("latin-1").strip().lower()
        header_value = value_bytes.decode("latin-1").strip()
        if header_name == "set-cookie":
            # Multiple Set-Cookie headers: merge for later splitting
            if "set-cookie" in response_headers:
                response_headers["set-cookie"] = (
                    response_headers["set-cookie"] + "\n" + header_value
                )
            else:
                response_headers["set-cookie"] = header_value
        else:
            response_headers[header_name] = header_value
    set_cookie_lines: List[str] = []
    merged_cookies = response_headers.get("set-cookie")
    if merged_cookies:
        set_cookie_lines.extend(merged_cookies.split("\n"))
    return status_code, response_headers, bytes_after_headers, set_cookie_lines


def read_body(
    tls_socket: ssl.SSLSocket,
    response_headers: Dict[str, str],
    bytes_after_headers: bytes,
) -> bytes:
    """Read entity body using Transfer-Encoding, Content-Length, or until EOF."""
    transfer_encoding = response_headers.get("transfer-encoding", "").lower()
    if "chunked" in transfer_encoding:
        body, _ = read_chunked_body_fixed(tls_socket, bytes_after_headers)
        return body
    content_length_header = response_headers.get("content-length")
    if content_length_header is not None:
        total_length = int(content_length_header)
        body_buffer = bytearray(bytes_after_headers)
        while len(body_buffer) < total_length:
            chunk = tls_socket.recv(min(65536, total_length - len(body_buffer)))
            if not chunk:
                raise ConnectionError("EOF before Content-Length satisfied")
            body_buffer.extend(chunk)
        return bytes(body_buffer[:total_length])
    # No length: read until server closes (Connection: close)
    body_buffer = bytearray(bytes_after_headers)
    while True:
        chunk = tls_socket.recv(8192)
        if not chunk:
            break
        body_buffer.extend(chunk)
    return bytes(body_buffer)


def decode_body_if_gzip(body: bytes, response_headers: Dict[str, str]) -> bytes:
    """Decompress gzip body when Content-Encoding says gzip (zlib handles gzip wrapper)."""
    content_encoding = response_headers.get("content-encoding", "").lower()
    if "gzip" in content_encoding:
        try:
            return zlib.decompress(body, 16 + zlib.MAX_WBITS)
        except Exception:
            return body
    return body


def tls_request(
    host: str,
    port: int,
    request_path: str,
    method: str = "GET",
    extra_headers: Optional[Dict[str, str]] = None,
    body: Optional[bytes] = None,
    cookie_jar: Optional[CookieJar] = None,
) -> Tuple[int, Dict[str, str], bytes, List[str]]:
    """One HTTPS request: new TCP connection, TLS, send, read response, return cookies."""
    ssl_context = ssl.create_default_context()
    tcp_socket = socket.create_connection((host, port), timeout=60)
    try:
        tls_socket = ssl_context.wrap_socket(tcp_socket, server_hostname=host)
    except Exception:
        tcp_socket.close()
        raise
    try:
        outgoing_headers: Dict[str, str] = dict(extra_headers or {})
        if cookie_jar and cookie_jar.header_value():
            outgoing_headers["Cookie"] = cookie_jar.header_value()
        raw_request = build_request(method, request_path, host, outgoing_headers, body)
        tls_socket.sendall(raw_request)
        status_code, response_headers, prefix_bytes, set_cookie_lines = raw_read_status_and_headers(
            tls_socket
        )
        response_body = read_body(tls_socket, response_headers, prefix_bytes)
        response_body = decode_body_if_gzip(response_body, response_headers)
        return status_code, response_headers, response_body, set_cookie_lines
    finally:
        try:
            tls_socket.close()
        except Exception:
            pass


# --- URL helpers for crawling only the target host ---
def resolve_url(relative_or_absolute: str, base_url: str) -> str:
    return urljoin(base_url, relative_or_absolute)


def same_site(url: str, crawl_host: str, crawl_port: int) -> bool:
    """True if URL is http(s) on the same host as the crawl; http:80 matches https:443 crawl."""
    parsed = urlparse(url)
    if parsed.scheme not in ("http", "https", ""):
        return False
    url_host = (parsed.hostname or "").lower()
    if url_host != crawl_host.lower():
        return False
    url_port = parsed.port
    if url_port is None:
        url_port = 80 if parsed.scheme == "http" else 443
    if url_port == crawl_port:
        return True
    if crawl_port == 443 and parsed.scheme == "http" and url_port == 80:
        return True
    return False


def normalize_url_for_visited(url: str) -> str:
    """Stable string for visited / queued deduplication (fragment stripped; default ports normalized)."""
    parsed = urlparse(url)
    scheme = (parsed.scheme or "https").lower()
    hostname = (parsed.hostname or "").lower()
    port = parsed.port
    if port is None:
        port = 443 if scheme == "https" else 80
    if (scheme == "https" and port == 443) or (scheme == "http" and port == 80):
        netloc = hostname
    else:
        netloc = f"{hostname}:{port}"
    return urlunparse((scheme, netloc, parsed.path or "/", "", parsed.query, ""))


def should_enqueue(url: str) -> bool:
    """Skip logout (kills session) and bare login path (not useful while authenticated)."""
    url_path = (urlparse(url).path or "").lower()
    if "/accounts/logout" in url_path:
        return False
    if url_path.rstrip("/") == "/accounts/login":
        return False
    return True


def upgrade_to_https(url: str, crawl_host: str, crawl_port: int) -> str:
    """Turn http://same-host/... into https://... for our TLS client."""
    parsed = urlparse(url)
    if (parsed.hostname or "").lower() != crawl_host.lower():
        return url
    if parsed.scheme != "http":
        return url
    path = parsed.path or "/"
    query = ("?" + parsed.query) if parsed.query else ""
    if crawl_port == 443:
        return f"https://{crawl_host}{path}{query}"
    return f"https://{crawl_host}:{crawl_port}{path}{query}"


# --- Extract <a href="..."> from HTML (parser + regex fallback) ---
ANCHOR_HREF_RE = re.compile(
    r"""<a\b[^>]*\bhref\s*=\s*(["'])(?P<href>.*?)\1""",
    re.IGNORECASE | re.DOTALL,
)


def collect_hrefs(markup: str) -> List[str]:
    """Collect hrefs; parameter is named markup so we do not shadow the html module."""
    link_parser = HrefCollector()
    try:
        link_parser.feed(markup)
        link_parser.close()
    except Exception:
        pass
    hrefs: List[str] = list(link_parser.hrefs)
    for match in ANCHOR_HREF_RE.finditer(markup):
        href = html.unescape(match.group("href").strip())
        if href and not href.lower().startswith(("javascript:", "mailto:", "#")):
            hrefs.append(href)
    unique_hrefs: List[str] = []
    already: set[str] = set()
    for href in hrefs:
        if href not in already:
            already.add(href)
            unique_hrefs.append(href)
    return unique_hrefs


class HrefCollector(html.parser.HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self.hrefs: List[str] = []

    def handle_starttag(self, tag: str, attrs: List[Tuple[str, Optional[str]]]) -> None:
        if tag.lower() != "a":
            return
        for attribute_name, attribute_value in attrs:
            if attribute_name.lower() == "href" and attribute_value:
                self.hrefs.append(html.unescape(attribute_value))


class HiddenInputCollector(html.parser.HTMLParser):
    """Collect hidden <input> fields (CSRF token, next) from the login form."""

    def __init__(self) -> None:
        super().__init__()
        self.inputs: Dict[str, str] = {}

    def handle_starttag(self, tag: str, attrs: List[Tuple[str, Optional[str]]]) -> None:
        if tag.lower() != "input":
            return
        attributes = {key.lower(): value for key, value in attrs if key}
        if attributes.get("type") == "hidden" and attributes.get("name"):
            field_name = attributes["name"]
            self.inputs[field_name] = attributes.get("value") or ""


def extract_login_form_action(login_page_html: str, page_url_after_get: str) -> str:
    """POST URL for login; action '.' means same URL as the GET (keep ?next= on the URL)."""
    form_match = re.search(
        r'<form[^>]+method\s*=\s*["\']post["\'][^>]*action\s*=\s*["\']([^"\']*)["\']',
        login_page_html,
        re.IGNORECASE | re.DOTALL,
    )
    if not form_match:
        form_match = re.search(
            r'<form[^>]+action\s*=\s*["\']([^"\']*)["\'][^>]*method\s*=\s*["\']post["\']',
            login_page_html,
            re.IGNORECASE | re.DOTALL,
        )
    if not form_match:
        return page_url_after_get
    action_attr = (form_match.group(1) or "").strip()
    if action_attr in (".", ""):
        return page_url_after_get
    return resolve_url(action_attr, page_url_after_get)


def http_request_follow(
    host: str,
    port: int,
    start_path: str,
    method: str,
    body: Optional[bytes],
    content_type: Optional[str],
    cookie_jar: CookieJar,
    max_redirects: int = 20,
    extra_headers: Optional[Dict[str, str]] = None,
) -> Tuple[int, bytes, str]:
    """Follow redirects until a non-redirect status (or cap); refresh cookies each hop."""
    request_path = start_path
    current_url = f"https://{host}:{port}{request_path}"
    redirect_count = 0
    service_unavailable_count = 0
    while redirect_count <= max_redirects and service_unavailable_count < 250:
        merged_extra: Dict[str, str] = {}
        if content_type:
            merged_extra["Content-Type"] = content_type
        if extra_headers:
            merged_extra.update(extra_headers)
        status_code, response_headers, response_body, set_cookie_lines = tls_request(
            host, port, request_path, method, merged_extra, body, cookie_jar
        )
        cookie_jar.set_from_lines(set_cookie_lines)
        if status_code == 503:
            service_unavailable_count += 1
            time.sleep(0.5)
            continue
        if status_code in (301, 302, 303, 307, 308):
            redirect_count += 1
            location = response_headers.get("location")
            if not location:
                return status_code, response_body, current_url
            next_url = resolve_url(location, current_url)
            next_parts = urlparse(next_url)
            if next_parts.hostname and next_parts.hostname.lower() != host.lower():
                return status_code, response_body, current_url
            request_path = next_parts.path or "/"
            if next_parts.query:
                request_path += "?" + next_parts.query
            if next_parts.port:
                port = next_parts.port
            current_url = next_url
            method = "GET"
            body = None
            content_type = None
            continue
        return status_code, response_body, current_url
    return 500, b"", current_url


def login(
    host: str,
    port: int,
    username: str,
    password: str,
    cookie_jar: CookieJar,
) -> None:
    """GET login page, POST credentials, verify we can load /fakebook/."""
    login_get_path = "/accounts/login/?next=/fakebook/"
    status_code, login_page_bytes, url_after_login_get = http_request_follow(
        host, port, login_get_path, "GET", None, None, cookie_jar
    )
    if status_code != 200:
        print(f"Login page GET failed: {status_code}", file=sys.stderr)
        sys.exit(1)
    login_page_html = login_page_bytes.decode("utf-8", errors="replace")
    form_action_url = extract_login_form_action(login_page_html, url_after_login_get)
    action_parts = urlparse(form_action_url)
    post_path = (action_parts.path or "/") + (
        ("?" + action_parts.query) if action_parts.query else ""
    )
    if action_parts.hostname and action_parts.hostname.lower() != host.lower():
        print("Login form points off-site", file=sys.stderr)
        sys.exit(1)

    hidden_inputs = HiddenInputCollector()
    hidden_inputs.feed(login_page_html)
    form_fields = dict(hidden_inputs.inputs)
    form_fields["username"] = username
    form_fields["password"] = password
    if "next" not in form_fields:
        form_fields["next"] = "/fakebook/"
    post_body = urlencode(form_fields).encode("ascii")
    post_content_type = "application/x-www-form-urlencoded"

    post_status, _response_body, _final_url = http_request_follow(
        host,
        port,
        post_path,
        "POST",
        post_body,
        post_content_type,
        cookie_jar,
        extra_headers={"Referer": url_after_login_get},
    )
    if post_status != 200:
        print(f"Login POST failed: HTTP {post_status}", file=sys.stderr)
        sys.exit(1)

    verify_session(host, port, cookie_jar)


def verify_session(host: str, port: int, cookie_jar: CookieJar) -> None:
    """After login, ensure /fakebook/ does not land on the login page."""
    status_code, _body, final_url = http_request_follow(
        host, port, "/fakebook/", "GET", None, None, cookie_jar
    )
    if status_code != 200 or "/accounts/login" in final_url:
        print(
            "Login failed: session not valid (check username/password).",
            file=sys.stderr,
        )
        sys.exit(1)


def extract_flags(page_html: str) -> List[str]:
    """Return unique flag tokens found in HTML (strict h3 first, then FLAG: anywhere)."""
    flags: List[str] = []
    seen_tokens: set[str] = set()
    for match in FLAG_RE_H3.finditer(page_html):
        token = match.group(2)
        if token not in seen_tokens:
            seen_tokens.add(token)
            flags.append(token)
    for match in FLAG_RE_ANY.finditer(page_html):
        token = match.group(1)
        if token not in seen_tokens:
            seen_tokens.add(token)
            flags.append(token)
    return flags


def crawl(
    host: str,
    port: int,
    cookie_jar: CookieJar,
    username: str,
    password: str,
) -> List[str]:
    """Breadth-first crawl until five flags or frontier empty."""
    start_url = f"https://{host}:{port}/fakebook/"
    url_frontier: deque[str] = deque([start_url])
    visited_normalized: set[str] = set()
    queued_normalized: set[str] = {normalize_url_for_visited(start_url)}
    flags_found: List[str] = []

    while url_frontier and len(flags_found) < 5:
        page_url = url_frontier.popleft()
        normalized_url = normalize_url_for_visited(page_url)
        if normalized_url in visited_normalized:
            continue
        visited_normalized.add(normalized_url)

        parsed_page = urlparse(page_url)
        request_path = (parsed_page.path or "/") + (
            ("?" + parsed_page.query) if parsed_page.query else ""
        )
        original_page_url = page_url
        original_request_path = request_path

        retry_count = 0
        login_retry_count = 0
        while retry_count < 100:
            status_code, response_headers, response_body, set_cookie_lines = tls_request(
                host, port, request_path, "GET", None, None, cookie_jar
            )
            cookie_jar.set_from_lines(set_cookie_lines)
            if status_code == 503:
                time.sleep(0.3 + 0.1 * retry_count)
                retry_count += 1
                continue
            if status_code in (301, 302, 303, 307, 308):
                location = response_headers.get("location")
                if not location:
                    break
                if "/accounts/login" in location and login_retry_count < 5:
                    login(host, port, username, password, cookie_jar)
                    login_retry_count += 1
                    page_url = original_page_url
                    request_path = original_request_path
                    continue
                next_url = resolve_url(location, page_url)
                if not same_site(next_url, host, port):
                    break
                page_url = next_url
                parsed_page = urlparse(page_url)
                request_path = (parsed_page.path or "/") + (
                    ("?" + parsed_page.query) if parsed_page.query else ""
                )
                continue
            if status_code in (403, 404):
                break
            if status_code != 200:
                break
            page_html = response_body.decode("utf-8", errors="replace")
            for flag_token in extract_flags(page_html):
                if flag_token not in flags_found:
                    flags_found.append(flag_token)
            for href in collect_hrefs(page_html):
                absolute_url = resolve_url(href, page_url)
                absolute_url = upgrade_to_https(absolute_url, host, port)
                if not same_site(absolute_url, host, port):
                    continue
                if not should_enqueue(absolute_url):
                    continue
                neighbor_key = normalize_url_for_visited(absolute_url)
                if neighbor_key not in visited_normalized and neighbor_key not in queued_normalized:
                    queued_normalized.add(neighbor_key)
                    url_frontier.append(absolute_url)
            break
        else:
            print("Too many 503s for URL", file=sys.stderr)
            sys.exit(1)

    return flags_found


def main() -> None:
    argument_parser = argparse.ArgumentParser(description="Fakebook crawler")
    argument_parser.add_argument("-s", "--server", default=DEFAULT_HOST, help="hostname")
    argument_parser.add_argument("-p", "--port", type=int, default=DEFAULT_PORT, help="port")
    argument_parser.add_argument("username")
    argument_parser.add_argument("password")
    cli_args = argument_parser.parse_args()

    cookie_jar = CookieJar()
    login(cli_args.server, cli_args.port, cli_args.username, cli_args.password, cookie_jar)
    flags = crawl(cli_args.server, cli_args.port, cookie_jar, cli_args.username, cli_args.password)
    if len(flags) < 5:
        print(f"Only found {len(flags)} flags before exhausting crawl.", file=sys.stderr)
        sys.exit(1)
    for flag_line in flags[:5]:
        print(flag_line)


if __name__ == "__main__":
    main()
