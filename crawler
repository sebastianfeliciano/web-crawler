#!/usr/bin/env python3
"""
Fakebook web crawler — HTTP/1.1 over TLS without urllib/requests/http clients.
Uses: socket, ssl, urllib.parse, html.parser, re.
"""
from __future__ import annotations

import argparse
import html
import html.parser
import re
import socket
import ssl
import sys
import time
import zlib
from typing import Dict, List, Optional, Tuple
from collections import deque
from urllib.parse import urlencode, urljoin, urlparse, urlunparse

DEFAULT_HOST = "fakebook.khoury.northeastern.edu"
DEFAULT_PORT = 443

# class may include other tokens, e.g. class="x secret_flag y"
FLAG_RE_H3 = re.compile(
    r"<h3[^>]*\bclass\s*=\s*['\"]([^'\"]*\bsecret_flag\b[^'\"]*)['\"][^>]*>\s*FLAG:\s*([A-Za-z0-9]{64})\s*</h3>",
    re.IGNORECASE | re.DOTALL,
)
# Fallback: assignment format guarantees FLAG: + 64 alphanumerics somewhere on the page
FLAG_RE_ANY = re.compile(r"FLAG:\s*([A-Za-z0-9]{64})")


def read_chunked_body_fixed(sock: ssl.SSLSocket, initial: bytes) -> Tuple[bytes, bytes]:
    """Decode chunked transfer; return (decoded_body, leftover_bytes_after_chunked)."""
    decoded = bytearray()
    buf = bytearray(initial)
    while True:
        while b"\r\n" not in buf:
            chunk = sock.recv(8192)
            if not chunk:
                raise ConnectionError("EOF in chunked size line")
            buf.extend(chunk)
        line_end = buf.index(b"\r\n")
        size_line = bytes(buf[:line_end])
        del buf[: line_end + 2]
        ext = size_line.split(b";", 1)[0].strip()
        chunk_len = int(ext, 16)
        if chunk_len == 0:
            # read trailers \r\n terminated blank line
            while b"\r\n\r\n" not in buf:
                more = sock.recv(8192)
                if not more:
                    break
                buf.extend(more)
            if b"\r\n\r\n" in buf:
                te = buf.index(b"\r\n\r\n")
                del buf[: te + 4]
            return bytes(decoded), bytes(buf)
        while len(buf) < chunk_len + 2:
            more = sock.recv(8192)
            if not more:
                raise ConnectionError("EOF in chunk data")
            buf.extend(more)
        decoded.extend(buf[:chunk_len])
        del buf[:chunk_len]
        if buf[:2] != b"\r\n":
            raise ValueError("invalid chunk terminator")
        del buf[:2]


class CookieJar:
    def __init__(self) -> None:
        self._cookies: Dict[str, str] = {}

    def set_from_lines(self, lines: List[str]) -> None:
        for line in lines:
            # Set-Cookie: name=value; Path=/ ...
            if not line.strip():
                continue
            part = line.split(";", 1)[0].strip()
            if "=" in part:
                name, val = part.split("=", 1)
                self._cookies[name.strip()] = val.strip()

    def header_value(self) -> str:
        if not self._cookies:
            return ""
        return "; ".join(f"{k}={v}" for k, v in self._cookies.items())


def build_request(
    method: str,
    path: str,
    host: str,
    headers: Optional[Dict[str, str]] = None,
    body: Optional[bytes] = None,
) -> bytes:
    h = {
        "Host": host,
        "Connection": "close",
        "User-Agent": "CS4700-FakebookCrawler/1.0",
    }
    if headers:
        h.update(headers)
    if body is not None:
        h["Content-Length"] = str(len(body))
    lines = [f"{method} {path} HTTP/1.1"]
    for k, v in h.items():
        lines.append(f"{k}: {v}")
    lines.append("")
    head = "\r\n".join(lines).encode("ascii") + b"\r\n"
    if body:
        return head + body
    return head


def raw_read_status_and_headers(sock: ssl.SSLSocket) -> Tuple[int, Dict[str, str], bytes, List[str]]:
    """Read until end of headers; return status, headers dict, prefix after headers, set-cookie lines."""
    buf = bytearray()
    while b"\r\n\r\n" not in buf:
        chunk = sock.recv(8192)
        if not chunk:
            raise ConnectionError("unexpected EOF while reading headers")
        buf.extend(chunk)
        if len(buf) > 2 * 1024 * 1024:
            raise ValueError("headers too large")
    idx = buf.index(b"\r\n\r\n")
    header_blob = bytes(buf[:idx])
    rest = bytes(buf[idx + 4 :])
    lines = header_blob.split(b"\r\n")
    status_line = lines[0].decode("latin-1", errors="replace")
    parts = status_line.split(None, 2)
    status = int(parts[1])
    hdrs: Dict[str, str] = {}
    for line in lines[1:]:
        if not line or b":" not in line:
            continue
        name, val = line.split(b":", 1)
        key = name.decode("latin-1").strip().lower()
        val_s = val.decode("latin-1").strip()
        if key == "set-cookie":
            # duplicate keys: append with newline marker for parsing
            if "set-cookie" in hdrs:
                hdrs["set-cookie"] = hdrs["set-cookie"] + "\n" + val_s
            else:
                hdrs["set-cookie"] = val_s
        else:
            hdrs[key] = val_s
    set_cookie_lines: List[str] = []
    sc = hdrs.get("set-cookie")
    if sc:
        set_cookie_lines.extend(sc.split("\n"))
    return status, hdrs, rest, set_cookie_lines


def read_body(
    sock: ssl.SSLSocket,
    headers: Dict[str, str],
    initial: bytes,
) -> bytes:
    te = headers.get("transfer-encoding", "").lower()
    if "chunked" in te:
        body, _ = read_chunked_body_fixed(sock, initial)
        return body
    cl = headers.get("content-length")
    if cl is not None:
        n = int(cl)
        buf = bytearray(initial)
        while len(buf) < n:
            chunk = sock.recv(min(65536, n - len(buf)))
            if not chunk:
                raise ConnectionError("EOF before Content-Length satisfied")
            buf.extend(chunk)
        return bytes(buf[:n])
    # No length — read until close
    buf = bytearray(initial)
    while True:
        chunk = sock.recv(8192)
        if not chunk:
            break
        buf.extend(chunk)
    return bytes(buf)


def tls_request(
    host: str,
    port: int,
    path: str,
    method: str = "GET",
    extra_headers: Optional[Dict[str, str]] = None,
    body: Optional[bytes] = None,
    cookie_jar: Optional[CookieJar] = None,
) -> Tuple[int, Dict[str, str], bytes, List[str]]:
    ctx = ssl.create_default_context()
    raw_sock = socket.create_connection((host, port), timeout=60)
    try:
        sock = ctx.wrap_socket(raw_sock, server_hostname=host)
    except Exception:
        raw_sock.close()
        raise
    try:
        h: Dict[str, str] = dict(extra_headers or {})
        if cookie_jar and cookie_jar.header_value():
            h["Cookie"] = cookie_jar.header_value()
        req = build_request(method, path, host, h, body)
        sock.sendall(req)
        status, hdrs, prefix, set_lines = raw_read_status_and_headers(sock)
        body_bytes = read_body(sock, hdrs, prefix)
        body_bytes = decode_body(body_bytes, hdrs)
        return status, hdrs, body_bytes, set_lines
    finally:
        try:
            sock.close()
        except Exception:
            pass


def resolve_url(url: str, base: str) -> str:
    return urljoin(base, url)


def same_site(url: str, host: str, port: int, scheme: str = "https") -> bool:
    """Same registrable host; treat http:80 and https:443 on that host as on-site when crawling https:443."""
    p = urlparse(url)
    if p.scheme not in ("http", "https", ""):
        return False
    h = (p.hostname or "").lower()
    if h != host.lower():
        return False
    pr = p.port
    if pr is None:
        if p.scheme == "http":
            pr = 80
        else:
            pr = 443
    if pr == port:
        return True
    # Common mismatch: page links use http://host/... while we crawl https://host:443/...
    if port == 443 and p.scheme == "http" and pr == 80:
        return True
    return False


def normalize_url_for_visited(url: str) -> str:
    p = urlparse(url)
    scheme = (p.scheme or "https").lower()
    host = (p.hostname or "").lower()
    pr = p.port
    if pr is None:
        pr = 443 if scheme == "https" else 80
    if (scheme == "https" and pr == 443) or (scheme == "http" and pr == 80):
        netloc = host
    else:
        netloc = f"{host}:{pr}"
    return urlunparse((scheme, netloc, p.path or "/", "", p.query, ""))


def should_enqueue(url: str) -> bool:
    """Do not follow logout (destroys session) or login (wastes crawl / odd state)."""
    path = (urlparse(url).path or "").lower()
    if "/accounts/logout" in path:
        return False
    if path.rstrip("/") == "/accounts/login":
        return False
    return True


def upgrade_to_https(url: str, host: str, port: int) -> str:
    """Rewrite http://<host> to https://<host>[:port] for crawling."""
    p = urlparse(url)
    if (p.hostname or "").lower() != host.lower():
        return url
    if p.scheme != "http":
        return url
    path = p.path or "/"
    q = ("?" + p.query) if p.query else ""
    if port == 443:
        return f"https://{host}{path}{q}"
    return f"https://{host}:{port}{path}{q}"


HREF_RE = re.compile(
    r"""<a\b[^>]*\bhref\s*=\s*(["'])(?P<href>.*?)\1""",
    re.IGNORECASE | re.DOTALL,
)


def collect_hrefs(markup: str) -> List[str]:
    """Prefer html.parser; regex catches links when markup is malformed for the parser."""
    coll = HrefCollector()
    try:
        coll.feed(markup)
        coll.close()
    except Exception:
        pass
    found: List[str] = list(coll.hrefs)
    for m in HREF_RE.finditer(markup):
        h = html.unescape(m.group("href").strip())
        if h and not h.lower().startswith(("javascript:", "mailto:", "#")):
            found.append(h)
    # de-dupe preserving order
    out: List[str] = []
    seen_h: set[str] = set()
    for h in found:
        if h not in seen_h:
            seen_h.add(h)
            out.append(h)
    return out


def decode_body(body: bytes, headers: Dict[str, str]) -> bytes:
    ce = headers.get("content-encoding", "").lower()
    if "gzip" in ce:
        try:
            return zlib.decompress(body, 16 + zlib.MAX_WBITS)
        except Exception:
            return body
    return body


class HrefCollector(html.parser.HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self.hrefs: List[str] = []

    def handle_starttag(self, tag: str, attrs: List[Tuple[str, Optional[str]]]) -> None:
        if tag.lower() != "a":
            return
        for name, val in attrs:
            if name.lower() == "href" and val:
                self.hrefs.append(html.unescape(val))


class HiddenInputCollector(html.parser.HTMLParser):
    def __init__(self) -> None:
        super().__init__()
        self.inputs: Dict[str, str] = {}

    def handle_starttag(self, tag: str, attrs: List[Tuple[str, Optional[str]]]) -> None:
        if tag.lower() != "input":
            return
        ad = {k.lower(): v for k, v in attrs if k}
        if ad.get("type") == "hidden" and "name" in ad and ad.get("name"):
            n = ad["name"]
            self.inputs[n] = ad.get("value") or ""


def extract_login_form_action(html: str, base_url: str) -> str:
    """Resolve POST target. action=\".\" means POST to the same URL as the login GET — not urljoin('.', ...)
    which incorrectly drops ?next=/fakebook/ from the path."""
    m = re.search(
        r'<form[^>]+method\s*=\s*["\']post["\'][^>]*action\s*=\s*["\']([^"\']*)["\']',
        html,
        re.IGNORECASE | re.DOTALL,
    )
    if not m:
        m = re.search(
            r'<form[^>]+action\s*=\s*["\']([^"\']*)["\'][^>]*method\s*=\s*["\']post["\']',
            html,
            re.IGNORECASE | re.DOTALL,
        )
    if not m:
        return base_url
    raw = (m.group(1) or "").strip()
    if raw in (".", ""):
        return base_url
    return resolve_url(raw, base_url)


def http_request_follow(
    host: str,
    port: int,
    start_path: str,
    method: str,
    body: Optional[bytes],
    content_type: Optional[str],
    cookie_jar: CookieJar,
    max_redirects: int = 20,
    extra_headers: Optional[Dict[str, str]] = None,
) -> Tuple[int, bytes, str]:
    """Perform one logical request following redirects. Returns (final_status, body, final_url)."""
    path = start_path
    current_url = f"https://{host}:{port}{path}"
    redirects = 0
    serv_failures = 0
    while redirects <= max_redirects and serv_failures < 250:
        extra: Dict[str, str] = {}
        if content_type:
            extra["Content-Type"] = content_type
        if extra_headers:
            extra.update(extra_headers)
        status, hdrs, body_bytes, set_lines = tls_request(
            host, port, path, method, extra, body, cookie_jar
        )
        cookie_jar.set_from_lines(set_lines)
        if status == 503:
            serv_failures += 1
            time.sleep(0.5)
            continue
        if status in (301, 302, 303, 307, 308):
            redirects += 1
            loc = hdrs.get("location")
            if not loc:
                return status, body_bytes, current_url
            next_u = resolve_url(loc, current_url)
            p = urlparse(next_u)
            if p.hostname and p.hostname.lower() != host.lower():
                return status, body_bytes, current_url
            path = p.path or "/"
            if p.query:
                path += "?" + p.query
            if p.port:
                port = p.port
            current_url = next_u
            method = "GET"
            body = None
            content_type = None
            continue
        return status, body_bytes, current_url
    return 500, b"", current_url


def login(host: str, port: int, username: str, password: str, jar: CookieJar) -> None:
    login_page_path = "/accounts/login/?next=/fakebook/"
    status, html_bytes, final_url = http_request_follow(
        host, port, login_page_path, "GET", None, None, jar
    )
    if status != 200:
        print(f"Login page GET failed: {status}", file=sys.stderr)
        sys.exit(1)
    html = html_bytes.decode("utf-8", errors="replace")
    action = extract_login_form_action(html, final_url)
    p = urlparse(action)
    post_path = (p.path or "/") + (("?" + p.query) if p.query else "")
    if p.hostname and p.hostname.lower() != host.lower():
        print("Login form points off-site", file=sys.stderr)
        sys.exit(1)

    hc = HiddenInputCollector()
    hc.feed(html)
    fields = dict(hc.inputs)
    fields["username"] = username
    fields["password"] = password
    if "next" not in fields:
        fields["next"] = "/fakebook/"
    body = urlencode(fields).encode("ascii")
    content_type = "application/x-www-form-urlencoded"

    status2, html2, _ = http_request_follow(
        host,
        port,
        post_path,
        "POST",
        body,
        content_type,
        jar,
        extra_headers={"Referer": final_url},
    )
    if status2 != 200:
        print(f"Login POST failed: HTTP {status2}", file=sys.stderr)
        sys.exit(1)

    verify_session(host, port, jar)


def verify_session(host: str, port: int, jar: CookieJar) -> None:
    """Ensure GET /fakebook/ does not end on the login page (wrong password looks like HTTP 200)."""
    status, _body, final_url = http_request_follow(
        host, port, "/fakebook/", "GET", None, None, jar
    )
    if status != 200 or "/accounts/login" in final_url:
        print(
            "Login failed: session not valid (check username/password).",
            file=sys.stderr,
        )
        sys.exit(1)


def extract_flags(page: str) -> List[str]:
    out: List[str] = []
    seen: set[str] = set()
    for m in FLAG_RE_H3.finditer(page):
        token = m.group(2)
        if token not in seen:
            seen.add(token)
            out.append(token)
    for m in FLAG_RE_ANY.finditer(page):
        token = m.group(1)
        if token not in seen:
            seen.add(token)
            out.append(token)
    return out


def crawl(
    host: str,
    port: int,
    jar: CookieJar,
    username: str,
    password: str,
) -> List[str]:
    start = f"https://{host}:{port}/fakebook/"
    frontier: deque[str] = deque([start])
    seen: set[str] = set()
    queued: set[str] = {normalize_url_for_visited(start)}
    flags_found: List[str] = []

    while frontier and len(flags_found) < 5:
        page_url = frontier.popleft()
        norm = normalize_url_for_visited(page_url)
        if norm in seen:
            continue
        seen.add(norm)

        p = urlparse(page_url)
        path = (p.path or "/") + (("?" + p.query) if p.query else "")
        original_page_url = page_url
        original_path = path

        retries = 0
        login_retries = 0
        while retries < 100:
            status, hdrs, body_bytes, set_lines = tls_request(
                host, port, path, "GET", None, None, jar
            )
            jar.set_from_lines(set_lines)
            if status == 503:
                time.sleep(0.3 + 0.1 * retries)
                retries += 1
                continue
            if status in (301, 302, 303, 307, 308):
                loc = hdrs.get("location")
                if not loc:
                    break
                # Session lost — server wants login; re-auth and retry this page
                if "/accounts/login" in loc and login_retries < 5:
                    login(host, port, username, password, jar)
                    login_retries += 1
                    page_url = original_page_url
                    path = original_path
                    continue
                nxt = resolve_url(loc, page_url)
                if not same_site(nxt, host, port):
                    break
                page_url = nxt
                p = urlparse(page_url)
                path = (p.path or "/") + (("?" + p.query) if p.query else "")
                continue
            if status in (403, 404):
                break
            if status != 200:
                break
            page_html = body_bytes.decode("utf-8", errors="replace")
            for f in extract_flags(page_html):
                if f not in flags_found:
                    flags_found.append(f)
            for href in collect_hrefs(page_html):
                abs_u = resolve_url(href, page_url)
                abs_u = upgrade_to_https(abs_u, host, port)
                if not same_site(abs_u, host, port):
                    continue
                if not should_enqueue(abs_u):
                    continue
                n2 = normalize_url_for_visited(abs_u)
                if n2 not in seen and n2 not in queued:
                    queued.add(n2)
                    frontier.append(abs_u)
            break
        else:
            print("Too many 503s for URL", file=sys.stderr)
            sys.exit(1)

    return flags_found


def main() -> None:
    ap = argparse.ArgumentParser(description="Fakebook crawler")
    ap.add_argument("-s", "--server", default=DEFAULT_HOST, help="hostname")
    ap.add_argument("-p", "--port", type=int, default=DEFAULT_PORT, help="port")
    ap.add_argument("username")
    ap.add_argument("password")
    args = ap.parse_args()

    jar = CookieJar()
    login(args.server, args.port, args.username, args.password, jar)
    flags = crawl(args.server, args.port, jar, args.username, args.password)
    if len(flags) < 5:
        print(f"Only found {len(flags)} flags before exhausting crawl.", file=sys.stderr)
        sys.exit(1)
    for f in flags[:5]:
        print(f)


if __name__ == "__main__":
    main()
